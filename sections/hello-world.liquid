{%- liquid
  assign bg_image = section.settings.header_image
  assign logo_image = section.settings.logo
-%}

<div
  class="phenex-hero"
  style="background-image: url({{ 'f.png' | asset_url }});"
>
  <!-- Darker overlay for better text readability -->
  <div class="overlay"></div>

  <div class="hero-inner">
    <div class="hero-left">
      {% if logo_image != blank %}
        <img
          src="{{ logo_image | image_url: width: 400 }}"
          width="250"
          height="auto"
          class="hero-logo"
          alt="{{ shop.name }}"
          loading="eager"
        >
      {% else %}
        <!-- Fallback if no logo setting is chosen -->
        <img
          src="{{ 'logowhite.png' | asset_url }}"
          width="150"
          height="auto"
          class="hero-logo"
          loading="eager"
        >
      {% endif %}

      <h1 class="hero-title">
        <span class="animate-text">{{ section.settings.title | escape }}</span>
      </h1>
      
      <p class="hero-subtitle animate-text" style="animation-delay: 0.2s;">
        {{ section.settings.subtitle | escape }}
      </p>

      <div class="hero-btn-wrapper animate-text" style="animation-delay: 0.4s;">
        <a
          href="/collections"
          class="hero-btn"
        >
          {{ section.settings.button_label | escape }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 8px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .phenex-hero {
    position: relative;
    min-height: 85vh; /* Slightly less than full screen looks more elegant */
    height: 85vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center; /* Vertically center content */
    justify-content: flex-start;
    padding: 0 8%;
    overflow: hidden;
    width: 100%;
    /* Remove the margin-left hack if this section is already full width in theme settings */
    /* margin-left: calc(-50vw + 50%);  <-- Uncomment only if you have white borders on sides */
  }

  .overlay {
    position: absolute;
    inset: 0;
    /* Darker gradient overlay for better contrast */
    background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 100%);
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1400px;
  }

  .hero-logo {
    width: 120px; /* Fixed size is usually cleaner than % */
    height: auto;
    margin-bottom: 2rem;
    display: block;
    object-fit: contain;
  }

  .hero-left {
    max-width: 650px;
  }

  .hero-title {
    font-size: clamp(3rem, 5vw, 6rem); /* Larger, bolder title */
    line-height: 1.1;
    color: #ffffff;
    font-weight: 800;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    margin: 0 0 1.5rem 0;
    text-shadow: 0 4px 10px rgba(0,0,0,0.3); /* Shadow helps readability */
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: #f0f0f0;
    margin: 0 0 2.5rem 0;
    line-height: 1.6;
    font-weight: 300;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    padding: 16px 48px;
    background-color: #b87333;
    color: #fff;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 50px; /* Pill shape */
    letter-spacing: 1.5px;
    font-size: 0.9rem;
    transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 0 10px 20px rgba(184, 115, 51, 0.3);
    border: 1px solid transparent;
  }

  .hero-btn:hover {
    background-color: #fff;
    color: #b87333;
    border-color: #b87333;
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.2);
  }

  /* Simple Fade Up Animation */
  .animate-text {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .phenex-hero {
      height: auto;
      min-height: 80vh;
      padding: 100px 5% 60px; /* More padding top for mobile */
      text-align: center;
      justify-content: center;
      background-position: center 30%; /* Adjust focus point on mobile */
    }

    .hero-left {
      margin: 0 auto;
    }

    .hero-logo {
      margin: 0 auto 1.5rem auto;
      width: 100px;
    }

    .hero-btn {
      width: 100%;
      justify-content: center;
      padding: 18px 30px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "header_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (Optional)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Welcome to Phenex"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Discover our new collection"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Collection"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}