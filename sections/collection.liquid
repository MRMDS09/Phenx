{%- comment -%}
  Renders the main collection page, including a header, sorting,
  product grid, and pagination.
{%- endcomment -%}

{{ 'collection-page.css' | asset_url | stylesheet_tag }}

{%- paginate collection.products by section.settings.products_per_page -%}

<div class="collection-container">
  
  <header class="collection-hero" style="background-image: url('{% if section.settings.background_image %}{{ section.settings.background_image | image_url: width: 2000 }}{% else %}{{ 'photoCollection.jpeg' | asset_url }}{% endif %}');">
    <div class="hero-overlay">
      <div class="hero-content">
        <h1 class="hero-title">{{ collection.title }}</h1>
        <nav class="breadcrumb page-width" aria-label="breadcrumb">
  <a href="/">Home</a>
  <span aria-hidden="true">›</span>
  {%- if collection -%}
    <a href="{{ collection.url }}">{{ collection.title }}</a>
    <span aria-hidden="true"></span>
  {%- endif -%}
  <span aria-current="page">{{ product.title }}</span>
</nav>
      </div>
    </div>
  </header>

<aside class="collection-sidebar">
  <div class="filter-card">
    <div class="filter-header">
      <span>Filters</span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="2" y1="14" x2="6" y2="14"/><line x1="10" y1="8" x2="14" y2="8"/><line x1="18" y1="16" x2="22" y2="16"/>
      </svg>
    </div>

    <div class="sidebar-block">
      <ul class="sidebar-category-list">
        <li><a href="#">T-Shirt <span class="chevron">›</span></a></li>
        <li><a href="#">Shoe <span class="chevron">›</span></a></li>
        <li><a href="#">Trousers <span class="chevron">›</span></a></li>
      </ul>
    </div>

    <div class="sidebar-block">
      <h3 class="sidebar-title">Price</h3>
      <div class="price-slider-container">
        <input type="range" min="0" max="500" value="500" class="price-range">
        <div class="price-labels">
          <span>$0</span>
          <span>$500</span>
        </div>
      </div>
    </div>

    <div class="sidebar-block">
      <h3 class="sidebar-title">Colors</h3>
      <div class="color-swatch-grid">
        <span class="swatch" style="background: #556B2F;"></span>
        <span class="swatch" style="background: #E0F2FE;"></span>
        <span class="swatch" style="background: #fff; border: 1px solid #ddd;"></span>
        <span class="swatch" style="background: #000;"></span>
        <span class="swatch" style="background: #FEF3C7;"></span>
        <span class="swatch" style="background: #fff; border: 1px solid #ddd;"></span>
        <span class="swatch" style="background: #FAF9F6; border: 1px solid #ddd;"></span>
        <span class="swatch" style="background: #666;"></span>
        <span class="swatch gradient"></span>
      </div>
    </div>

    <button class="filter-reset-btn">Reset Filter</button>
  </div>
</aside>

<aside class="collection-sidebar">
  <form id="FacetFiltersForm">
    <div class="filter-card">
      <div class="filter-header">
        <span>Filters</span>
      </div>

      <div class="sidebar-block">
        <h3 class="sidebar-title">Availability</h3>
        <div class="sidebar-filter-item">
          <input type="checkbox" name="filter.v.availability" value="1" id="in-stock">
          <label for="in-stock">In stock</label>
        </div>
      </div>

      <div class="sidebar-block">
        <h3 class="sidebar-title">Price</h3>
        <div class="price-slider-container">
          <input type="range" name="filter.v.price.gte" min="0" max="500" value="0" class="price-range">
          <input type="range" name="filter.v.price.lte" min="0" max="500" value="500" class="price-range">
        </div>
      </div>

      <button type="button" class="filter-reset-btn">Reset Filter</button>
    </div>
  </form>
</aside>

<main>
    <div class="product-grid" style="--columns: {{ section.settings.columns }};">
    <div class="filter-card">
      <div class="filter-header">
        <span>Filters</span>
      </div>

      <div class="sidebar-block">
        <h3 class="sidebar-title">Availability</h3>
        <div class="sidebar-filter-item">
          <input type="checkbox" name="filter.v.availability" value="1" id="in-stock">
          <label for="in-stock">In stock</label>
        </div>
      </div>

      <div class="sidebar-block">
        <h3 class="sidebar-title">Price</h3>
        <div class="price-slider-container">
          <input type="range" name="filter.v.price.gte" min="0" max="500" value="0" class="price-range">
          <input type="range" name="filter.v.price.lte" min="0" max="500" value="500" class="price-range">
        </div>
      </div>

      <button type="button" class="filter-reset-btn">Reset Filter</button>
    </div>
  </form>

      </div>

      <div class="product-grid" style="--columns: {{ section.settings.columns }};">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="pagination">{{ paginate | default_pagination }}</div>
      {%- endif -%}
    </main>
  </div>
{%- endpaginate -%}
<script>
  document.getElementById('sort-by').addEventListener('change', function() {
    const url = new URL(window.location.href);
    url.searchParams.set('sort_by', this.value);
    window.location = url.href;
  });
</script>

{% schema %}
{
  "name": "Collection Page",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "Products per page",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Columns on desktop",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Show collection image",
      "default": true
    }
  ]
}

{
  "sections": {
    "collection": {
      "background_image": "Background image"
    }
  }
}
{%- endsection %}
