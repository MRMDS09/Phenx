{%- comment -%}
  Renders the site footer, including navigation and brand information,
  using a block-based system.
{%- endcomment -%}

{{ 'footer.css' | asset_url | stylesheet_tag }}
<footer class="footer-umino">
  <div class="page-width">
    <div class="footer-top-grid">
      
      <div class="footer-column brand-info">
        <h2 class="footer-logo">Phenix</h2>
        <p>Oujda, Morocco</p>
        <p>+212-6800-2628</p>
        <p>phenix@gmail.com</p>
        <div class="footer-socials">
          <a href="#"><i class="icon-instagram"></i></a>
          <a href="#"><i class="icon-tiktok"></i></a>
          <a href="#"><i class="icon-youtube"></i></a>
          <a href="#"><i class="icon-x"></i></a>
        </div>
      </div>

      <div class="footer-column">
        <h3 class="footer-title">COMPANY</h3>
        <ul>
          <li><a href="#">About Us</a></li>
          <li><a href="#">Our Stores</a></li>
          <li><a href="#">Contact Us</a></li>
          <li><a href="#">Size Guide</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h3 class="footer-title">CUSTOMER SERVICE</h3>
        <ul>
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Shipping & Return</a></li>
          <li><a href="#">Term & Conditions</a></li>
          <li><a href="#">Store Locations</a></li>
        </ul>
      </div>

      <div class="footer-column newsletter-col">
        <h3 class="footer-title">SIGN UP TO NEWSLETTER</h3>
        <p>Enter your email address to get $10 off your first order and free shipping.</p>
        <form class="footer-newsletter-form">
          <input type="email" placeholder="Enter your email..." required>
          <button type="submit">SUBSCRIBE</button>
        </form>
      </div>

    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-left">
        
        <span>Morooco (MAD )</span>
      </div>
      <div class="footer-copyright">
        © {{- 'now' | date: ' %Y ' -}}  - Phenix Store. All Rights Reserved
      </div>
      <div class="footer-payment-icons">
        <img src="{{ 'visa.png' | asset_url }}" alt="Visa" width="40" height="24">
        <img src="{{ 'mastercard.png' | asset_url }}" alt="Mastercard" width="40" height="24">
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link List",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "brand_info",
      "name": "Brand Information",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_logo",
          "label": "Show brand name",
          "default": true
        },
        {
          "type": "textarea",
          "id": "brand_description",
          "label": "Brand description",
          "default": "A short sentence about your brand."
        },
        {
          "type": "header",
          "content": "Social Media"
        },
        {
          "type": "url",
          "id": "social_twitter",
          "label": "Twitter URL"
        },
        {
          "type": "url",
          "id": "social_facebook",
          "label": "Facebook URL"
        },
        {
          "type": "url",
          "id": "social_instagram",
          "label": "Instagram URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_list" },
        { "type": "brand_info" }
      ]
    }
  ]
}
{% endschema %}
